      "blocks": []
    },
    {
      "id": "1-what-is-the-kol-program",
      "question": "1. What is the KOL Program?",
      "blocks": [
        {
          "type": "text",
          "value": "The KOL (Key Opinion Leader) Program allows content creators and influencers to promote the exchange and earn commissions from referred users."
        }
      ]
    },
    {
      "id": "2-how-do-i-join-the-kol-program",
      "question": "2. How do I join the KOL Program?",
      "blocks": [
        {
          "type": "text",
          "value": "Apply through the KOL registration page. Approved KOLs receive a unique referral link or promotion code."
        }
      ]
    },
    {
