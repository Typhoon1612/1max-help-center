      "question": "Referral Program – FAQ",
      "blocks": []
    },
    {
      "id": "1-what-is-the-referral-program",
      "question": "1. What is the Referral Program?",
      "blocks": [
        {
          "type": "text",
          "value": "Invite friends to join the exchange and earn rewards when they trade."
        }
      ]
    },
    {
      "id": "2-how-do-i-share-my-referral-link",
      "question": "2. How do I share my referral link?",
      "blocks": [
        {
          "type": "text",
          "value": "Copy your unique referral link from the Referral page and share it with your friends."
        }
      ]
    },
    {
      "id": "3-how-do-i-earn-referral-rewards",
      "question": "3. How do I earn referral rewards?",
      "blocks": [
        {
          "type": "text",
          "value": "You earn rewards or commissions when users who register through your referral link complete eligible trades."
        }
      ]
    },
    {
      "id": "4-when-are-referral-rewards-credited",
      "question": "4. When are referral rewards credited?",
      "blocks": [
        {
          "type": "text",
          "value": "Referral rewards are usually credited automatically after the referred user meets the required conditions."
        }
      ]
    },
    {
      "id": "5-are-there-limits-to-referral-rewards",
      "question": "5. Are there limits to referral rewards?",
      "blocks": [
        {
          "type": "text",
          "value": "Yes. Certain promotions, campaigns, or user tiers may have limits. Please refer to the Referral Terms & Conditions for details."
        }
      ]
    },
    {
      "id": "6-who-is-eligible-to-be-referred",
      "question": "6. Who is eligible to be referred?",
      "blocks": [
        {
          "type": "text",
          "value": "Referred users must:"
        },
        {
          "type": "list",
          "value": [
            "Register using your referral link or code"
          ]
        },
        {
          "type": "list",
          "value": [
            "Meet eligibility requirements such as trading activity or verification status"
          ]
        },
        {
          "type": "text",
          "value": "Self-referrals are not allowed."
        }
      ]
    },
    {
      "id": "7-which-trades-qualify-for-referral-rewards",
      "question": "7. Which trades qualify for referral rewards?",
      "blocks": [
        {
          "type": "text",
          "value": "Only eligible trades (such as spot or futures trades, depending on program rules) qualify."
        },
        {
          "type": "text",
          "value": "Certain products or promotions may be excluded."
        }
      ]
    },
    {
