      "blocks": [
        {
          "type": "text",
          "value": "Yes. KOLs must meet platform requirements, which may include:"
        },
        {
          "type": "list",
          "value": [
            "Minimum audience size"
          ]
        },
        {
          "type": "list",
          "value": [
            "Content quality and relevance"
          ]
        },
        {
          "type": "list",
          "value": [
            "Promotional activity compliance"
          ]
        }
      ]
    },
    {
